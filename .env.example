# ── App ────────────────────────────────────────────────
APP_NAME=FitnessWS
APP_ENV=development

# ── Database ───────────────────────────────────────────
DB_HOST=127.0.0.1
DB_NAME=fitness_db
DB_USER=fitness_user
DB_PASS=s
DB_CHARSET=utf8mb4

# ── JWT ────────────────────────────────────────────────
# Generate a strong secret: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=replace-me-with-64-hex-chars
JWT_TTL=86400

# ── CORS ───────────────────────────────────────────────
# Comma-separated origins. Use "*" only for local development.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate limiting ──────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SEC=900

# ── AI / OpenRouter ────────────────────────────────────
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=
AI_MODEL=google/gemini-flash-1.5
