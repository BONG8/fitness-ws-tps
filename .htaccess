RewriteEngine On

# Forward Authorization header to PHP (Apache strips it by default)
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# Block direct .php access (only external requests, not internal rewrites)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^.*\.php$ - [F,L]

# Block direct access to subdirectories
RewriteRule ^(lib|resources)/ - [F,L]

# Route everything to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ index.php [QSA,L]

<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS, DELETE, PUT"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    
    # Rispondi 200 OK alle richieste OPTIONS di preflight
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]
</IfModule>